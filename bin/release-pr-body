#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: release-pr-body <service> <new-sha> [environment] [old-sha]"
  echo "  service      daedalus | icarus | odin | olympus"
  echo "  new-sha      new full SHA to release"
  echo "  environment  staging | production | both (default)"
  echo "  old-sha      optional currently deployed SHA for single-environment releases"
  exit 1
}

[[ $# -lt 2 ]] && usage

SERVICE=$1
NEW_SHA=$2
ENVIRONMENT=both
OLD_SHA=${4:-}
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/release-common.sh
source "$ROOT/lib/release-common.sh"

release_require_service "$SERVICE"

if [[ $# -ge 3 ]]; then
  case "$3" in
    staging|production|prod|both)
      ENVIRONMENT=$(release_normalize_environment "$3")
      ;;
    *)
      ENVIRONMENT=staging
      OLD_SHA=$3
      ;;
  esac
fi

if [[ $# -ge 4 && "$ENVIRONMENT" == "both" ]]; then
  echo "Error: explicit old-sha is only supported for single-environment releases" >&2
  exit 1
fi

release_require_initialized_repos "$ROOT" "$SERVICE"
release_fetch_origin "$ROOT" "$SERVICE"
release_require_commit "$ROOT" "$SERVICE" "new" "$NEW_SHA"

STAGING_OLD_SHA=$(release_read_deployed_sha "$ROOT" "$SERVICE" staging)
PRODUCTION_OLD_SHA=$(release_read_deployed_sha "$ROOT" "$SERVICE" production)

if [[ "$ENVIRONMENT" == "staging" || "$ENVIRONMENT" == "production" ]]; then
  if [[ -n "$OLD_SHA" ]]; then
    if [[ "$ENVIRONMENT" == "staging" ]]; then
      STAGING_OLD_SHA=$OLD_SHA
    else
      PRODUCTION_OLD_SHA=$OLD_SHA
    fi
  fi
fi

BODY_FILE=$(mktemp)
trap 'rm -f "$BODY_FILE"' EXIT

release_print_pr_content "$ROOT" "$SERVICE" "$NEW_SHA" "$ENVIRONMENT" "$BODY_FILE" "$STAGING_OLD_SHA" "$PRODUCTION_OLD_SHA"
