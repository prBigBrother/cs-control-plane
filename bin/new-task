#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=../lib/task-common.sh
source "$ROOT/lib/task-common.sh"

link_if_missing() {
  local source_path="$1"
  local target_path="$2"

  if [ -e "$target_path" ] || [ -L "$target_path" ]; then
    return 0
  fi

  mkdir -p "$(dirname "$target_path")"
  ln -s "$source_path" "$target_path"
}

link_globbed_env_files() {
  local source_dir="$1"
  local target_dir="$2"

  for env_file in "$source_dir"/.env*; do
    [ -f "$env_file" ] || continue
    link_if_missing "$env_file" "$target_dir/$(basename "$env_file")"
  done
}

link_runtime_assets() {
  local repo_path="$1"
  local worktree_path="$2"

  # Link root node_modules when present in the base checkout.
  if [ -f "$repo_path/package.json" ] && [ -d "$repo_path/node_modules" ]; then
    link_if_missing "$repo_path/node_modules" "$worktree_path/node_modules"
  elif [ -f "$repo_path/package.json" ]; then
    echo "Warning: $repo_path/node_modules is missing; run ./bin/bootstrap before creating worktrees if you want node_modules linked." >&2
  fi

  # Link repo-level env files such as .env and .env.local.
  link_globbed_env_files "$repo_path" "$worktree_path"

  # Link package node_modules and env files for workspace-style repos.
  if [ -d "$repo_path/packages" ]; then
    while IFS= read -r package_json; do
      package_dir="$(dirname "$package_json")"
      relative_dir="${package_dir#"$repo_path"/}"
      target_dir="$worktree_path/$relative_dir"

      if [ -d "$package_dir/node_modules" ]; then
        link_if_missing "$package_dir/node_modules" "$target_dir/node_modules"
      fi

      link_globbed_env_files "$package_dir" "$target_dir"
    done < <(find "$repo_path/packages" -mindepth 2 -maxdepth 4 -name package.json | sort)
  fi
}

if [ "$#" -lt 2 ]; then
  echo "Usage: new-task <repo> <eng-id> [slug] [type]" >&2
  exit 1
fi

REPO="$1"
ENG_ID="$2"
SLUG="${3:-}"
TYPE="${4:-feature}"
REPO_PATH="$ROOT/repos/$REPO"

case "$SLUG" in
  feature|bug|hotfix|release)
    TYPE="$SLUG"
    SLUG=""
    ;;
esac

if [ -z "$SLUG" ]; then
  resolved_status=0
  resolved_slug="$(resolve_existing_worktree_slug "$ROOT" "$REPO" "$ENG_ID")" || resolved_status=$?

  if [ "$resolved_status" -eq 0 ]; then
    SLUG="$resolved_slug"
  elif [ "$resolved_status" -eq 2 ]; then
    exit 2
  else
    SLUG="task"
  fi
fi

WORKTREE_PATH="$ROOT/worktrees/$REPO/$ENG_ID-$SLUG"
BRANCH="$TYPE/$ENG_ID/$SLUG"

if [ "$REPO" = "dinah" ]; then
  echo "dinah is read-only in this control plane" >&2
  exit 2
fi

if [ ! -e "$REPO_PATH/.git" ]; then
  echo "Repo not initialized: $REPO_PATH" >&2
  exit 3
fi

mkdir -p "$ROOT/worktrees/$REPO"
git -C "$REPO_PATH" fetch origin main:refs/remotes/origin/main
BASE_REF="origin/main"

if [ -f "$WORKTREE_PATH/.git" ] || [ -d "$WORKTREE_PATH/.git" ] || [ -d "$WORKTREE_PATH" ]; then
  link_runtime_assets "$REPO_PATH" "$WORKTREE_PATH"
  "$ROOT/bin/install-local-opencode" "$WORKTREE_PATH" engineering repo >/dev/null
  echo "$WORKTREE_PATH"
  exit 0
fi

git -C "$REPO_PATH" worktree add -b "$BRANCH" "$WORKTREE_PATH" "$BASE_REF"

if [ -f "$REPO_PATH/AGENTS.md" ]; then
  cp "$REPO_PATH/AGENTS.md" "$WORKTREE_PATH/AGENTS.md"
fi

link_runtime_assets "$REPO_PATH" "$WORKTREE_PATH"

"$ROOT/bin/install-local-opencode" "$WORKTREE_PATH" engineering repo

echo "$WORKTREE_PATH"
