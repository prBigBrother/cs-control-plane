#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 3 ]; then
  echo "Usage: install-local-opencode <repo-or-worktree-path> [engineering|migration|release|external|full] [repo|control-plane|full]" >&2
  exit 1
fi

TARGET_INPUT="$1"
PROFILE="${2:-engineering}"
AGENT_PROFILE="${3:-repo}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

relative_link_target() {
  local link_dir="$1"
  local source_path="$2"

  node -e '
const path = require("node:path")
const from = process.argv[1]
const to = process.argv[2]
const relative = path.relative(from, to) || "."
console.log(relative.startsWith(".") ? relative : `./${relative}`)
' "$link_dir" "$source_path"
}

link_relative() {
  local source_path="$1"
  local link_path="$2"
  local link_dir
  local relative_target

  link_dir="$(dirname "$link_path")"
  mkdir -p "$link_dir"
  relative_target="$(relative_link_target "$link_dir" "$source_path")"
  ln -sfn "$relative_target" "$link_path"
}

case "$PROFILE" in
  engineering) CONFIG="$ROOT/opencode.json" ;;
  migration) CONFIG="$ROOT/opencode.migration.json" ;;
  release) CONFIG="$ROOT/opencode.release.json" ;;
  external) CONFIG="$ROOT/opencode.external.json" ;;
  full) CONFIG="$ROOT/opencode.full.json" ;;
  *)
    echo "Unknown OpenCode profile: $PROFILE" >&2
    echo "Expected one of: engineering, migration, release, external, full" >&2
    exit 4
    ;;
esac

case "$AGENT_PROFILE" in
  repo|control-plane|full) ;;
  *)
    echo "Unknown OpenCode agent profile: $AGENT_PROFILE" >&2
    echo "Expected one of: repo, control-plane, full" >&2
    exit 5
    ;;
esac

case "$TARGET_INPUT" in
  /*) TARGET="$TARGET_INPUT" ;;
  *) TARGET="$ROOT/$TARGET_INPUT" ;;
esac

if [ ! -d "$TARGET" ]; then
  echo "Target directory not found: $TARGET" >&2
  exit 2
fi

TARGET="$(cd "$TARGET" && pwd)"

GIT_DIR="$(git -C "$TARGET" rev-parse --git-dir 2>/dev/null || true)"
if [ -z "$GIT_DIR" ]; then
  echo "Target is not a git worktree: $TARGET" >&2
  exit 3
fi

case "$GIT_DIR" in
  /*) ;;
  *) GIT_DIR="$TARGET/$GIT_DIR" ;;
esac

if mkdir -p "$GIT_DIR/info" 2>/dev/null && { [ -e "$GIT_DIR/info/exclude" ] || touch "$GIT_DIR/info/exclude" 2>/dev/null; }; then
  for entry in "/opencode.json" "/.opencode"; do
    if ! grep -qxF "$entry" "$GIT_DIR/info/exclude"; then
      if [ ! -w "$GIT_DIR/info/exclude" ]; then
        break
      fi
      printf "%s\n" "$entry" >> "$GIT_DIR/info/exclude"
    fi
  done
else
  echo "Warning: could not update $GIT_DIR/info/exclude; continuing with OpenCode install." >&2
fi

install_agent_pack() {
  local pack_name="$1"
  local pack_dir="$ROOT/.opencode/agent-packs/$pack_name"

  if [ ! -d "$pack_dir" ]; then
    return 0
  fi

  while IFS= read -r agent_file; do
    [ -n "$agent_file" ] || continue
    link_relative "$agent_file" "$TARGET/.opencode/agents/$(basename "$agent_file")"
  done < <(find "$pack_dir" -maxdepth 1 -type f -name '*.md' | sort)
}

if [ "$CONFIG" != "$TARGET/opencode.json" ]; then
  link_relative "$CONFIG" "$TARGET/opencode.json"
fi

if [ -L "$TARGET/.opencode" ]; then
  rm "$TARGET/.opencode"
fi

mkdir -p "$TARGET/.opencode/agents"

if [ "$TARGET" != "$ROOT" ]; then
  link_relative "$ROOT/.opencode/commands" "$TARGET/.opencode/commands"
  link_relative "$ROOT/.opencode/tools" "$TARGET/.opencode/tools"
fi

find "$TARGET/.opencode/agents" -maxdepth 1 \( -type l -o -type f \) -name '*.md' -delete
install_agent_pack common

case "$AGENT_PROFILE" in
  repo)
    install_agent_pack repo
    ;;
  control-plane)
    install_agent_pack control-plane
    ;;
  full)
    install_agent_pack control-plane
    install_agent_pack repo
    ;;
esac

echo "Installed shared OpenCode $PROFILE config with $AGENT_PROFILE agents into $TARGET"
