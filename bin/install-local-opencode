#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  echo "Usage: install-local-opencode <repo-or-worktree-path> [engineering|migration|release|external|full]" >&2
  exit 1
fi

TARGET_INPUT="$1"
PROFILE="${2:-engineering}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

case "$PROFILE" in
  engineering) CONFIG="$ROOT/opencode.json" ;;
  migration) CONFIG="$ROOT/opencode.migration.json" ;;
  release) CONFIG="$ROOT/opencode.release.json" ;;
  external) CONFIG="$ROOT/opencode.external.json" ;;
  full) CONFIG="$ROOT/opencode.full.json" ;;
  *)
    echo "Unknown OpenCode profile: $PROFILE" >&2
    echo "Expected one of: engineering, migration, release, external, full" >&2
    exit 4
    ;;
esac

case "$TARGET_INPUT" in
  /*) TARGET="$TARGET_INPUT" ;;
  *) TARGET="$ROOT/$TARGET_INPUT" ;;
esac

if [ ! -d "$TARGET" ]; then
  echo "Target directory not found: $TARGET" >&2
  exit 2
fi

GIT_DIR="$(git -C "$TARGET" rev-parse --git-dir 2>/dev/null || true)"
if [ -z "$GIT_DIR" ]; then
  echo "Target is not a git worktree: $TARGET" >&2
  exit 3
fi

case "$GIT_DIR" in
  /*) ;;
  *) GIT_DIR="$TARGET/$GIT_DIR" ;;
esac

mkdir -p "$GIT_DIR/info"
touch "$GIT_DIR/info/exclude"

for entry in "/opencode.json" "/.opencode"; do
  if ! grep -qxF "$entry" "$GIT_DIR/info/exclude"; then
    printf "%s\n" "$entry" >> "$GIT_DIR/info/exclude"
  fi
done

ln -sfn "$CONFIG" "$TARGET/opencode.json"
ln -sfn "$ROOT/.opencode" "$TARGET/.opencode"

echo "Installed shared OpenCode $PROFILE config into $TARGET"
