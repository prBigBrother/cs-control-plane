#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: compare <service> <environment> [target-sha]"
  echo "  service      daedalus | icarus | odin | olympus"
  echo "  environment  staging | production | prod"
  echo "  target-sha   optional full or partial commit SHA to compare against"
  exit 1
}

[[ $# -lt 2 || $# -gt 3 ]] && usage

SERVICE=$1
ENVIRONMENT_INPUT=$2
TARGET_SHA_INPUT=${3:-}
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=../lib/release-common.sh
source "$ROOT/lib/release-common.sh"

release_require_service "$SERVICE"
ENVIRONMENT=$(release_normalize_compare_environment "$ENVIRONMENT_INPUT")
release_require_initialized_repos "$ROOT" "$SERVICE"
release_fetch_origin "$ROOT" "$SERVICE"

DEPLOYED_SHA=$(release_read_deployed_sha "$ROOT" "$SERVICE" "$ENVIRONMENT")
release_require_commit "$ROOT" "$SERVICE" "deployed" "$DEPLOYED_SHA"

if [ -n "$TARGET_SHA_INPUT" ]; then
  TARGET_SHA=$(release_resolve_target_sha "$ROOT" "$SERVICE" "$TARGET_SHA_INPUT")
  TARGET_LABEL="Target"
else
  TARGET_SHA=$(release_resolve_target_sha "$ROOT" "$SERVICE")
  TARGET_LABEL="origin/main"
fi

DEPLOYED_SHORT=$(release_short_sha "$ROOT" "$SERVICE" "$DEPLOYED_SHA")
TARGET_SHORT=$(release_short_sha "$ROOT" "$SERVICE" "$TARGET_SHA")

echo "Service:      $SERVICE"
echo "Environment:  $ENVIRONMENT"
echo "Deployed:     $DEPLOYED_SHA"
echo "$TARGET_LABEL:         $TARGET_SHA"
echo ""

if [ "$DEPLOYED_SHA" = "$TARGET_SHA" ]; then
  echo "No commits between deployed $DEPLOYED_SHORT and $TARGET_LABEL $TARGET_SHORT."
  exit 0
fi

echo "Commits ($DEPLOYED_SHORT..$TARGET_SHORT):"
release_commit_list "$ROOT" "$SERVICE" "$DEPLOYED_SHA" "$TARGET_SHA" '- `%h` %s (%an <%ae>)'
