#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=../lib/task-common.sh
source "$ROOT/lib/task-common.sh"

if [ "$#" -lt 2 ]; then
  echo "Usage: cleanup-task <repo> <eng-id> [slug] [type]" >&2
  exit 1
fi

REPO="$1"
ENG_ID="$2"
SLUG="${3:-}"
TYPE="${4:-feature}"
REPO_PATH="$ROOT/repos/$REPO"

case "$SLUG" in
  feature|bug|hotfix|release)
    TYPE="$SLUG"
    SLUG=""
    ;;
esac

if [ -z "$SLUG" ]; then
  resolved_status=0
  resolved_slug="$(resolve_existing_worktree_slug "$ROOT" "$REPO" "$ENG_ID")" || resolved_status=$?

  if [ "$resolved_status" -eq 0 ]; then
    SLUG="$resolved_slug"
  elif [ "$resolved_status" -eq 2 ]; then
    exit 2
  else
    echo "Error: no worktree found for $REPO $ENG_ID; pass the slug explicitly." >&2
    exit 2
  fi
fi

WORKTREE_PATH="$ROOT/worktrees/$REPO/$ENG_ID-$SLUG"
BRANCH="$TYPE/$ENG_ID/$SLUG"

if [ ! -e "$REPO_PATH/.git" ]; then
  echo "Repo not initialized: $REPO_PATH" >&2
  exit 3
fi

if [ -d "$WORKTREE_PATH" ]; then
  ACTUAL_BRANCH="$(git -C "$WORKTREE_PATH" branch --show-current 2>/dev/null || true)"
  if [ -n "$ACTUAL_BRANCH" ]; then
    BRANCH="$ACTUAL_BRANCH"
  fi
  git -C "$REPO_PATH" worktree remove "$WORKTREE_PATH"
else
  echo "Worktree already removed: $WORKTREE_PATH"
fi

git -C "$REPO_PATH" worktree prune

if ! git -C "$REPO_PATH" branch --list "$BRANCH" | grep -q .; then
  for candidate_type in feature bug hotfix release; do
    candidate_branch="$candidate_type/$ENG_ID/$SLUG"
    if git -C "$REPO_PATH" branch --list "$candidate_branch" | grep -q .; then
      BRANCH="$candidate_branch"
      break
    fi
  done
fi

if git -C "$REPO_PATH" branch --list "$BRANCH" | grep -q .; then
  git -C "$REPO_PATH" branch -d "$BRANCH"
else
  echo "Branch already deleted: $BRANCH"
fi
