{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "/Users/prbigbrother/Sites/citizenshipper/control-plane/instructions/shared.md",
    "/Users/prbigbrother/Sites/citizenshipper/control-plane/instructions/engineering.md",
    "/Users/prbigbrother/Sites/citizenshipper/control-plane/instructions/migration.md",
    "/Users/prbigbrother/Sites/citizenshipper/control-plane/instructions/releases.md",
    "/Users/prbigbrother/Sites/citizenshipper/control-plane/instructions/memory.md"
  ],
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/coverage/**",
      "**/.git/**",
      "worktrees/**"
    ]
  },
  "plugin": [
    ".opencode/plugins/mem0.mjs"
  ],
  "tool": {
    "worktree-map": {
      "description": "Resolve a repo, ENG id, and slug to a worktree path.",
      "command": [
        "node",
        ".opencode/tools/worktree-map.mjs"
      ]
    },
    "repo-profile": {
      "description": "Show metadata for a control-plane repo profile.",
      "command": [
        "node",
        ".opencode/tools/repo-profile.mjs"
      ]
    },
    "memory-write": {
      "description": "Persist a distilled decision or runbook note into Mem0.",
      "command": [
        "node",
        ".opencode/tools/memory-write.mjs"
      ]
    }
  },
  "permission": {
    "external_directory": {
      "/Users/prbigbrother/Sites/citizenshipper/control-plane/worktrees": "allow",
      "/Users/prbigbrother/Sites/citizenshipper/control-plane/worktrees/**": "allow"
    },
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow"
  }
}
